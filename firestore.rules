rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function isSameClub(docClubId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.clubId == docClubId;
    }

    function isAdmin() {
      let userData = getUserData();
      return isAuthenticated() && userData != null && (userData.role == 'superadmin' || userData.role == 'owner' || userData.role == 'coach');
    }

    function isSuperAdmin() {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role == 'superadmin';
    }

    function isSuperAdminEmail() {
      return isAuthenticated() && request.auth.token.email == 'victor.defreitas.pro@gmail.com';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isSameClub(resource.data.clubId) || isSuperAdmin() || isSuperAdminEmail();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin() || isSuperAdminEmail();
      allow delete: if isSuperAdmin() || isSuperAdminEmail();
    }

    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isSuperAdminEmail() || (isAdmin() && isSameClub(clubId));
    }

    match /driveFiles/{fileId} {
      allow read: if isAuthenticated() && (isSameClub(resource.data.clubId) || resource.data.sharedWith.hasAny([getUserData().id]) || isSuperAdminEmail());
      allow create: if isAuthenticated() && (isSameClub(request.resource.data.clubId) || isSuperAdminEmail());
      allow update: if isAuthenticated() && ((isSameClub(resource.data.clubId) && (isOwner(resource.data.createdBy) || isAdmin())) || isSuperAdminEmail());
      allow delete: if isAuthenticated() && ((isSameClub(resource.data.clubId) && (isOwner(resource.data.createdBy) || isAdmin())) || isSuperAdminEmail());
    }

    match /driveFolders/{folderId} {
      allow read: if isAuthenticated() && (isSameClub(resource.data.clubId) || isSuperAdminEmail());
      allow create: if isAuthenticated() && (isSameClub(request.resource.data.clubId) || isSuperAdminEmail());
      allow update: if isAuthenticated() && ((isSameClub(resource.data.clubId) && (isOwner(resource.data.createdBy) || isAdmin())) || isSuperAdminEmail());
      allow delete: if isAuthenticated() && ((isSameClub(resource.data.clubId) && (isOwner(resource.data.createdBy) || isAdmin())) || isSuperAdminEmail());
    }

    // Default rule for all other collections
    match /{document=**} {
      allow read: if isAuthenticated() && (
        isSameClub(resource.data.clubId) || 
        resource.data.clubId == 'global' || 
        isSuperAdmin() ||
        isSuperAdminEmail()
      );
      allow create, update: if isAuthenticated() && (
        isSameClub(request.resource.data.clubId) || 
        isSuperAdmin() ||
        isSuperAdminEmail()
      );
      allow delete: if isAuthenticated() && (
        isSameClub(resource.data.clubId) || 
        isSuperAdmin() ||
        isSuperAdminEmail()
      );
    }
  }
}
